DB_PASSWORD="motdepasse"
DB_USER="user_db"
DB_NAME="dbname"
DB_PORT=5432
DB_HOST="db"

DATABASE_URL="postgresql://user_db:motdepasse@db:5432/dbname"

PORT=3000

OWNER_EMAIL="randommail@gmail.com"
OWNER_NAME="Owner"
OWNER_PASSWORD="OwnerPassword"

APP_EMAIL="randommail@gmail.com"

SECRET_KEY="SecretKey"
REFRESH_KEY="RefreshKey"
RESET_KEY="ResetKey"

ACCESS_EXPIRACY="15m"
REFRESH_EXPIRACY="7d"

# Dev : "http://localhost:5173" — Prod : "https://valentinneff.dev"
# Utilisé par CORS (credentials) : doit correspondre à l'origine réelle du front.
FRONTEND_URL="http://localhost:5173"
GOOGLE_APP_PASSWORD="Google App Password"

# Dev : "dev" — Prod : "production"
# OBLIGATOIRE en prod : active les cookies secure + SameSite=None (HTTPS).
NODE_ENV="dev"

PASSWORD_SALT='GeneratePasswordSalt'

VITE_API_URL="/api"

# En prod le conteneur client est mappé sur 80:80 et 443:443 (cf docker-compose.prod.yaml),
# ces variables ne servent qu'au compose de dev.
LOCAL_PORT="80"
LOCAL_PORT_SSL="443"

# Adresse de bind du serveur Node. En conteneur : "0.0.0.0" (ne pas mettre le domaine).
HOSTNAME="0.0.0.0"